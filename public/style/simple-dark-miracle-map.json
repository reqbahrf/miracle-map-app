{
  "version": 8,
  "name": "Miracle Dark GeoStat",
  "sources": {
    "ne2_shaded": {
      "type": "raster",
      "tiles": [
        "https://tiles.openfreemap.org/natural_earth/ne2sr/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "maxzoom": 6
    },
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",

  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#001f3f"
      }
    },

    {
      "id": "terrain",
      "type": "raster",
      "source": "ne2_shaded",
      "maxzoom": 7,
      "paint": {
        "raster-opacity": 0.15
      }
    },

    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#002b5c"
      }
    },

    {
      "id": "admin-level-2",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "all",
        ["==", ["get", "admin_level"], 2],
        ["!=", ["get", "maritime"], 1]
      ],
      "paint": {
        "line-color": "#b8860b",
        "line-width": 2,
        "line-opacity": 0.85
      }
    },

    {
      "id": "admin-level-4",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "all",
        ["==", ["get", "admin_level"], 4],
        ["!=", ["get", "maritime"], 1]
      ],
      "paint": {
        "line-color": "#a67c00",
        "line-dasharray": [2, 2],
        "line-width": 1,
        "line-opacity": 0.6
      }
    },

    {
      "id": "road-major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "match",
        ["get", "class"],
        ["motorway", "primary", "trunk"],
        true,
        false
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d4a017",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.5,
          10,
          1.5,
          14,
          3
        ]
      }
    },

    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "match",
        ["get", "class"],
        ["secondary", "tertiary", "minor"],
        true,
        false
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#4f5d6b",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.5,
          12,
          1,
          16,
          2
        ]
      }
    },
    {
      "id": "country-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", ["get", "class"], "country"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 16,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#f5f2e9",
        "text-halo-color": "#001f3f",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "region-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "match",
        ["get", "class"],
        ["state", "province", "region"],
        true,
        false
      ],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 13
      },
      "paint": {
        "text-color": "#e6d8b5",
        "text-halo-color": "#001f3f",
        "text-halo-width": 1
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#d4a017",
        "text-halo-color": "#001f3f",
        "text-halo-width": 1
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#2c3e50",
        "fill-opacity": 0.6
      }
    }
  ]
}
